# MongoDB Database Connection
# For MongoDB Atlas, use this format:
# DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority"
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/aaronyx?retryWrites=true&w=majority"

# JWT Secret for Authentication (generate a secure random string)
JWT_SECRET="your-super-secret-jwt-key-here-change-in-production"

# Environment
NODE_ENV="development"

# Socket Server URL (for local development, leave empty for production)
NEXT_PUBLIC_SOCKET_URL=""

# LiveKit Configuration (for video calls)
# Get these from https://cloud.livekit.io/
# For self-hosted LiveKit, use your server URL
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"
